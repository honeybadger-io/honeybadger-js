{
  "name": "@honeybadger-io/nextjs",
  "version": "5.10.13",
  "description": "Next.js integration for Honeybadger",
  "keywords": [
    "nextjs",
    "honeybadger",
    "vercel",
    "react"
  ],
  "author": {
    "name": "Pangratios Cosma",
    "email": "pangratios.cosma@honeybadger.io"
  },
  "homepage": "https://github.com/honeybadger-io/honeybadger-js/tree/master/packages/nextjs",
  "license": "MIT",
  "main": "dist/honeybadger-nextjs.cjs.js",
  "module": "dist/honeybadger-nextjs.esm.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "edge-light": {
        "types": "./dist/edge.d.ts",
        "import": "./dist/honeybadger-nextjs-edge.esm.js",
        "require": "./dist/honeybadger-nextjs-edge.cjs.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/honeybadger-nextjs.esm.js",
      "require": "./dist/honeybadger-nextjs.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "scripts"
  ],
  "bin": {
    "honeybadger-copy-config-files": "scripts/copy-config-files-bin.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honeybadger-io/honeybadger-js.git"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json && rollup -c && rollup -c rollup.scripts.config.js && tsc --build tsconfig.types.json",
    "test": "jest --config jest.config.js"
  },
  "bugs": {
    "url": "https://github.com/honeybadger-io/honeybadger-js/issues"
  },
  "peerDependencies": {
    "@honeybadger-io/react": ">= 6.1.25",
    "next": ">= 13.x"
  },
  "dependencies": {
    "@honeybadger-io/js": "workspace:^",
    "@honeybadger-io/webpack": "workspace:^"
  },
  "devDependencies": {
    "@honeybadger-io/react": "workspace:^",
    "@rollup/plugin-commonjs": "^22.0.0",
    "@types/jest": "^29.5.3",
    "jest": "^29.6.1",
    "mock-fs": "^5.2.0",
    "next": "^13.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rollup": "^2.70.2",
    "rollup-plugin-copy": "^3.4.0",
    "ts-jest": "^29.1.1",
    "typescript": "^4.6.3"
  },
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public"
  }
}
